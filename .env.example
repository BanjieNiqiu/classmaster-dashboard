# MongoDB数据库连接
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database
# 应用的数据库名称
DATABASE_NAME=class_affairs_db

# JWT认证配置
# JWT令牌签名密钥，用于生成和验证用户身份令牌
JWT_SECRET=your_jwt_secret_key_here
# JWT令牌过期时间，格式为数字加单位（如1d表示一天）
JWT_EXPIRES_IN=7d

# LLM服务配置
# 大语言模型API密钥，用于调用外部LLM服务（如OpenAI、Claude等）
LLM_API_KEY=your_llm_api_key_here
# LLM API基础路径，支持自定义端点或代理服务
LLM_API_BASE_PATH=https://api.openai.com/v1
# 使用的LLM模型名称，例如gpt-3.5-turbo、gpt-4等
LLM_MODEL=gpt-3.5-turbo

# 文件存储配置
# 对象存储服务URL，用于访问上传的文件资源
STORAGE_OSS_URL=https://your-bucket-name.oss-cn-beijing.aliyuncs.com
# OSS访问密钥ID，用于身份认证
STORAGE_OSS_ACCESS_KEY=your_oss_access_key_id
# OSS密钥，用于请求签名认证
STORAGE_OSS_SECRET_KEY=your_oss_secret_access_key
# 最大上传文件大小限制，单位为MB
MAX_UPLOAD_SIZE=50

# 系统安全配置
# 管理员用户ID，用于初始化系统管理员账户
ADMIN_USER_ID=admin001
# 管理员密码哈希值，由bcrypt等算法生成的安全存储密码
ADMIN_PASSWORD_HASH=$2b$10$EpjC9z5KZ8eJmX3QY6RkEe7WtVwL2N1oOqI5pP9sT4uU3vV2wX1yZ
# 会话加密密钥，用于加密客户端会话数据
SESSION_SECRET=your_session_encryption_secret

# 应用配置
# 运行环境：development（开发）或production（生产）
NODE_ENV=development
# 应用监听的端口号
PORT=3000
# 允许跨域请求的源，多个可用逗号分隔，*表示允许所有
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com

# 外部服务配置
# 邮件服务API密钥，用于发送系统通知邮件
EMAIL_SERVICE_API_KEY=your_email_service_api_key
# 短信服务API密钥，用于发送短信验证码或提醒
SMS_SERVICE_API_KEY=your_sms_service_api_key